@{
    ViewBag.Title = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AjoTopup - Login</title>
    <!-- Google Fonts: Montserrat (for Optimistic VF feel) -->
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;700&display=swap" rel="stylesheet">
    
    <!-- Bootstrap 4.6.2 CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" crossorigin="anonymous">
    
    <!-- FontAwesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" crossorigin="anonymous" />

    <style>
        :root {
            --primary: #0064e0;
            --primary-deep: #0457cb;
            --on-primary: #ffffff;
            --ink-deep: #0a1317;
            --ink: #1c1e21;
            --surface-soft: #f1f4f7;
            --hairline: #ced0d4;
            --hairline-soft: #dee3e9;
            --critical-strong: #f0284a;
            --disabled-text: #bcc0c4;
            --canvas: #ffffff;
            --font-family: 'Montserrat', sans-serif;
        }

        body {
            font-family: var(--font-family);
            background-color: var(--surface-soft);
            color: var(--ink);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            letter-spacing: -0.14px;
        }

        .login-card {
            background-color: var(--canvas);
            border: 1px solid var(--hairline-soft);
            border-radius: 24px; /* xxl rounding */
            padding: 40px;
            width: 100%;
            max-width: 440px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        }

        .login-logo {
            font-size: 28px;
            font-weight: 700;
            color: var(--ink-deep);
            text-align: center;
            margin-bottom: 8px;
            letter-spacing: -0.8px;
        }

        .login-logo span {
            color: var(--primary);
        }

        .login-subtitle {
            font-size: 14px;
            color: var(--ink);
            text-align: center;
            margin-bottom: 32px;
            font-weight: 300;
        }

        /* Form Controls */
        .form-group label {
            font-weight: 700;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--ink-deep);
            margin-bottom: 8px;
        }

        .ajo-input {
            border: 1px solid var(--hairline);
            border-radius: 8px; /* lg rounding */
            height: 48px;
            padding: 12px 16px;
            font-size: 14px;
            transition: all 0.2s ease-in-out;
            background-color: var(--canvas);
            color: var(--ink);
        }

        .ajo-input:focus {
            border: 2px solid var(--primary);
            box-shadow: none;
            outline: none;
        }

        /* Button */
        .btn-ajo-login {
            background-color: var(--primary);
            color: var(--on-primary);
            font-weight: 700;
            border-radius: 100px; /* full rounding */
            height: 48px;
            font-size: 15px;
            border: none;
            transition: all 0.2s ease-in-out;
            margin-top: 16px;
        }

        .btn-ajo-login:hover, .btn-ajo-login:active, .btn-ajo-login:focus {
            background-color: var(--primary-deep);
            color: var(--on-primary);
            box-shadow: none;
        }

        /* Alert */
        .ajo-alert {
            background-color: rgba(228, 30, 63, 0.1);
            color: var(--critical-strong);
            border-radius: 12px;
            padding: 14px 16px;
            font-size: 13px;
            border: none;
            margin-bottom: 24px;
            display: none;
        }
    </style>
</head>
<body>

    <div class="login-card">
        <div class="login-logo">Ajo<span>Topup</span></div>
        <div class="login-subtitle">Silakan masuk ke portal operator Anda</div>

        <div id="loginAlert" class="ajo-alert">
            <i class="fas fa-exclamation-circle mr-2"></i> <span id="alertMsg">Username atau password salah.</span>
        </div>

        <form id="frmLogin">
            <div class="form-group">
                <label for="txtusername">Username</label>
                <input type="text" id="txtusername" class="form-control ajo-input" placeholder="Masukkan username Anda" autocomplete="username" required />
            </div>

            <div class="form-group">
                <label for="txtpassword">Password</label>
                <input type="password" id="txtpassword" class="form-control ajo-input" placeholder="Masukkan password Anda" autocomplete="current-password" required />
            </div>

            <button id="btnLogin" type="button" class="btn btn-ajo-login btn-block">
                Masuk <i class="fas fa-arrow-right ml-2"></i>
            </button>
        </form>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js" crossorigin="anonymous"></script>
    <script>
        $(document).ready(function () {
            // Trigger login on enter key
            $('#txtusername, #txtpassword').keypress(function (e) {
                if (e.which == 13) {
                    $('#btnLogin').click();
                }
            });

            $('#btnLogin').click(function () {
                var username = $('#txtusername').val();
                var password = $('#txtpassword').val();

                if (username == "") {
                    showAlert("Silakan isi Username");
                    $('#txtusername').focus();
                    return;
                }
                if (password == "") {
                    showAlert("Silakan isi Password");
                    $('#txtpassword').focus();
                    return;
                }

                $('#btnLogin').prop('disabled', true).html('<i class="fas fa-spinner fa-spin mr-2"></i> Memproses...');

                $.ajax({
                    url: '@Url.Action("CekAuth", "Login")',
                    type: 'POST',
                    data: {
                        txtusername: username,
                        txtpassword: password
                    },
                    success: function (ret) {
                        $('#btnLogin').prop('disabled', false).html('Masuk <i class="fas fa-arrow-right ml-2"></i>');
                        if (ret.result) {
                            window.location = '@Url.Content("~/dashboard")';
                        } else {
                            showAlert(ret.msg);
                        }
                    },
                    error: function () {
                        $('#btnLogin').prop('disabled', false).html('Masuk <i class="fas fa-arrow-right ml-2"></i>');
                        showAlert("Terjadi kesalahan koneksi sistem.");
                    }
                });
            });

            function showAlert(msg) {
                $('#alertMsg').text(msg);
                $('#loginAlert').fadeIn();
            }
        });
    </script>
</body>
</html>