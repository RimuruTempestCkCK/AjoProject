@{
    ViewBag.Title = "Tambah Produk Baru";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-lg-8 col-md-10">
        <div class="mb-4 d-flex align-items-center justify-content-between">
            <div>
                <h2 class="font-weight-700">Tambah Produk Baru</h2>
                <p class="text-secondary">Tambah produk pulsa telekomunikasi baru ke database.</p>
            </div>
            <a href="@Url.Content("~/product")" class="btn btn-ajo-secondary">
                <i class="fas fa-arrow-left mr-1"></i> Batal & Kembali
            </a>
        </div>

        <div class="ajo-card ajo-card-lg">
            <div class="ajo-card-header">
                <h5 class="font-weight-700 mb-0"><i class="fas fa-plus-circle mr-2 text-primary"></i>Data Produk</h5>
            </div>

            <form id="frmCreateProduct">
                <!-- Product Code -->
                <div class="form-group mb-4">
                    <label for="txtProductCode">KODE PRODUK (PRODUCT CODE)</label>
                    <input type="text" id="txtProductCode" class="form-control ajo-input" placeholder="Contoh: TSEL10" style="text-transform: uppercase;" required />
                    <small class="form-text text-secondary mt-1">Harus unik dan tidak boleh diubah setelah disimpan.</small>
                </div>

                <!-- Product Name -->
                <div class="form-group mb-4">
                    <label for="txtProductName">NAMA PRODUK</label>
                    <input type="text" id="txtProductName" class="form-control ajo-input" placeholder="Contoh: Telkomsel 10.000" required />
                </div>

                <!-- Provider -->
                <div class="form-group mb-4">
                    <label for="ddlProvider">PROVIDER</label>
                    <select id="ddlProvider" class="form-control ajo-input" required>
                        <option value="" disabled selected>-- Pilih Provider --</option>
                        <option value="Telkomsel">Telkomsel</option>
                        <option value="Indosat">Indosat</option>
                        <option value="XL">XL</option>
                        <option value="Axis">Axis</option>
                    </select>
                </div>

                <!-- Price -->
                <div class="form-group mb-4">
                    <label for="numPrice">HARGA PRODUK (PRICE)</label>
                    <input type="number" id="numPrice" class="form-control ajo-input" min="1" placeholder="Contoh: 10000" required />
                </div>

                <!-- Commission -->
                <div class="form-group mb-4">
                    <label for="numCommission">KOMISI AGEN</label>
                    <input type="number" id="numCommission" class="form-control ajo-input" min="0" placeholder="Contoh: 250" value="0" />
                </div>

                <!-- Is Active -->
                <div class="form-group mb-4">
                    <label class="d-block">STATUS AKTIF</label>
                    <div class="custom-control custom-switch mt-2">
                        <input type="checkbox" class="custom-control-input" id="chkActive" checked>
                        <label class="custom-control-label font-weight-500" for="chkActive">Aktifkan produk untuk transaksi pengisian pulsa</label>
                    </div>
                </div>

                <!-- Submit -->
                <button type="button" id="btnSave" class="btn btn-ajo-primary btn-block py-2">
                    <i class="fas fa-save mr-1"></i> Simpan Produk
                </button>
            </form>
        </div>
    </div>
</div>

@section jsContent {
    <script>
        $(document).ready(function () {
            $('#btnSave').click(function () {
                var code = $('#txtProductCode').val().trim().toUpperCase();
                var name = $('#txtProductName').val().trim();
                var provider = $('#ddlProvider').val();
                var price = parseFloat($('#numPrice').val());
                var commission = parseFloat($('#numCommission').val()) || 0;
                var active = $('#chkActive').is(':checked');

                if (!code) {
                    alert("Silakan isi Kode Produk.");
                    $('#txtProductCode').focus();
                    return;
                }
                if (!name) {
                    alert("Silakan isi Nama Produk.");
                    $('#txtProductName').focus();
                    return;
                }
                if (!provider) {
                    alert("Silakan pilih Provider.");
                    $('#ddlProvider').focus();
                    return;
                }
                if (isNaN(price) || price <= 0) {
                    alert("Harga produk harus lebih dari 0.");
                    $('#numPrice').focus();
                    return;
                }

                $('#btnSave').prop('disabled', true).html('<i class="fas fa-spinner fa-spin mr-2"></i> Menyimpan...');

                $.ajax({
                    url: '@Url.Action("Create", "Product")',
                    type: 'POST',
                    data: {
                        productCode: code,
                        productName: name,
                        provider: provider,
                        price: price,
                        commission: commission,
                        isActive: active
                    },
                    success: function (res) {
                        $('#btnSave').prop('disabled', false).html('<i class="fas fa-save mr-1"></i> Simpan Produk');
                        if (res.success) {
                            alert(res.message);
                            window.location = '@Url.Content("~/product")';
                        } else {
                            alert("Gagal menyimpan: " + res.message);
                        }
                    },
                    error: function () {
                        $('#btnSave').prop('disabled', false).html('<i class="fas fa-save mr-1"></i> Simpan Produk');
                        alert("Terjadi kesalahan sistem.");
                    }
                });
            });
        });
    </script>
}

