@{
    ViewBag.Title = "Log Request/Response";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var logs = ViewBag.Logs as List<Dictionary<string, object>>;
}

<div class="row">
    <div class="col-12 mb-4">
        <h2 class="font-weight-700">Log Request/Response</h2>
        <p class="text-secondary">Daftar rekaman payload integrasi API untuk debugging dan audit transaksi.</p>
    </div>
</div>

<div class="ajo-card">
    <div class="ajo-card-header">
        <h5 class="font-weight-700 mb-0"><i class="fas fa-terminal mr-2 text-primary"></i>100 Log Terbaru</h5>
    </div>

    @if (logs != null && logs.Count > 0)
    {
        <div class="table-responsive">
            <table class="ajo-table">
                <thead>
                    <tr>
                        <th>Trx ID</th>
                        <th>Tipe Log</th>
                        <th>URL Endpoint</th>
                        <th class="text-center">HTTP Status</th>
                        <th>Waktu Proses</th>
                        <th>Tanggal Log</th>
                        <th class="text-center">Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in logs)
                    {
                        var id = Convert.ToInt32(log["Id"]);
                        var trxId = log["TrxId"].ToString();
                        var logType = log["LogType"].ToString();
                        var url = log["RequestUrl"] != DBNull.Value ? log["RequestUrl"].ToString() : "-";
                        var statusCode = log["ResponseStatusCode"] != DBNull.Value ? log["ResponseStatusCode"].ToString() : "-";
                        var duration = log["ExecutionTime"] != DBNull.Value ? log["ExecutionTime"].ToString() + " ms" : "-";
                        var createdDate = Convert.ToDateTime(log["CreatedDate"]).ToString("dd-MMM-yyyy HH:mm:ss.fff");

                        string typeBadge = "badge-secondary";
                        if (logType == "MVC_TO_API") { typeBadge = "badge-primary"; }
                        else if (logType == "API_TO_PROVIDER") { typeBadge = "badge-warning"; }
                        else if (logType == "API_RESPONSE") { typeBadge = "badge-success"; }

                        <tr>
                            <td class="font-weight-700"><a href="@Url.Content("~/transaction/detail/")@trxId">@trxId</a></td>
                            <td>
                                <span class="badge @typeBadge rounded-pill px-3 py-1 font-weight-700 text-uppercase" style="font-size: 10px;">@logType</span>
                            </td>
                            <td class="small text-muted" style="max-width: 250px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@url</td>
                            <td class="text-center">
                                @if (statusCode == "200")
                                {
                                    <span class="badge badge-success font-weight-700">@statusCode</span>
                                }
                                else if (statusCode != "-")
                                {
                                    <span class="badge badge-danger font-weight-700">@statusCode</span>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </td>
                            <td>@duration</td>
                            <td class="small text-secondary">@createdDate</td>
                            <td class="text-center">
                                <button type="button" class="btn btn-sm btn-ajo-primary btn-view" data-id="@id" style="padding: 4px 14px; font-size: 11px;">
                                    <i class="far fa-eye"></i> Detail Payload
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5 text-secondary">
            <i class="fas fa-receipt mb-3" style="font-size: 32px;"></i>
            <p class="mb-0">Belum ada rekaman log transaksi.</p>
        </div>
    }
</div>

<!-- Modal: Log Details -->
<div class="modal fade" id="logDetailModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
        <div class="modal-content" style="border-radius: 20px; border: none; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
            <div class="modal-header border-bottom-0 p-4 pb-2">
                <h5 class="font-weight-700 mb-0"><i class="fas fa-code mr-2 text-primary"></i>Detail Payload Log</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body p-4 pt-2">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <span class="text-secondary small d-block">ID TRANSAKSI</span>
                        <strong id="detTrxId" class="text-dark">-</strong>
                    </div>
                    <div class="col-md-6">
                        <span class="text-secondary small d-block">TANGGAL LOG</span>
                        <strong id="detDate" class="text-dark">-</strong>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-12">
                        <span class="text-secondary small d-block">REQUEST URL</span>
                        <code id="detUrl" style="word-break: break-all;">-</code>
                    </div>
                </div>

                <!-- Request Body -->
                <div id="divReqBody" class="mb-3" style="display: none;">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <span class="text-secondary small font-weight-700">REQUEST BODY (JSON)</span>
                        <button type="button" class="btn btn-link btn-sm text-secondary p-0 btn-copy" id="btnCopyReq" data-clipboard="">
                            <i class="far fa-copy"></i> Salin
                        </button>
                    </div>
                    <pre style="background-color: var(--surface-soft); color: var(--charcoal); padding: 12px; border-radius: 8px; font-size: 12px; max-height: 200px; overflow-y: auto;"><code id="detReqBody"></code></pre>
                </div>

                <!-- Response Body -->
                <div id="divResBody" class="mb-3" style="display: none;">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <span class="text-secondary small font-weight-700">RESPONSE BODY (JSON)</span>
                        <button type="button" class="btn btn-link btn-sm text-secondary p-0 btn-copy" id="btnCopyRes" data-clipboard="">
                            <i class="far fa-copy"></i> Salin
                        </button>
                    </div>
                    <pre style="background-color: var(--surface-soft); color: var(--charcoal); padding: 12px; border-radius: 8px; font-size: 12px; max-height: 200px; overflow-y: auto;"><code id="detResBody"></code></pre>
                </div>
            </div>
            <div class="modal-footer border-top-0 p-4 pt-0">
                <button type="button" class="btn btn-ajo-secondary btn-block" data-dismiss="modal" style="font-size: 13px;">Tutup</button>
            </div>
        </div>
    </div>
</div>

@section jsContent {
    <script>
        $(document).ready(function () {
            // View Details
            $('.btn-view').click(function () {
                var id = $(this).data('id');
                
                $.ajax({
                    url: '@Url.Content("~/Admin/LogDetail/")' + id,
                    type: 'GET',
                    success: function (res) {
                        if (res.success) {
                            var data = res.data;
                            
                            $('#detTrxId').html('<a href="@Url.Content("~/transaction/detail/")' + data.trxId + '">' + data.trxId + '</a>');
                            $('#detDate').text(data.createdDate);
                            $('#detUrl').text(data.requestUrl || "-");

                            // Request body
                            if (data.requestBody) {
                                $('#detReqBody').text(data.requestBody);
                                $('#btnCopyReq').attr('data-clipboard', data.requestBody);
                                $('#divReqBody').show();
                            } else {
                                $('#divReqBody').hide();
                            }

                            // Response body
                            if (data.responseBody) {
                                $('#detResBody').text(data.responseBody);
                                $('#btnCopyRes').attr('data-clipboard', data.responseBody);
                                $('#divResBody').show();
                            } else {
                                $('#divResBody').hide();
                            }

                            $('#logDetailModal').modal('show');
                        } else {
                            alert("Gagal: " + res.message);
                        }
                    },
                    error: function () {
                        alert("Terjadi kesalahan koneksi sistem.");
                    }
                });
            });

            // Copy helper
            $('.btn-copy').click(function () {
                var text = $(this).attr('data-clipboard');
                var button = $(this);
                
                navigator.clipboard.writeText(text).then(function() {
                    button.html('<i class="fas fa-check"></i> Tersalin');
                    setTimeout(function() {
                        button.html('<i class="far fa-copy"></i> Salin');
                    }, 2000);
                }).catch(function() {
                    alert("Gagal menyalin.");
                });
            });
        });
    </script>
}

