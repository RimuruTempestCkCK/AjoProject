<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - AjoTopup</title>

    <!-- Google Fonts: Montserrat (for Optimistic VF feel) -->
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;700&display=swap" rel="stylesheet">
    
    <!-- Bootstrap 4.6.1 CSS from local assets or CDN -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" crossorigin="anonymous">
    
    <!-- FontAwesome for beautiful icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" crossorigin="anonymous" />

    <style>
        :root {
            --primary: #0064e0;
            --primary-deep: #0457cb;
            --primary-soft: rgba(0, 145, 255, 0.15);
            --on-primary: #ffffff;
            --ink-button: #000000;
            --on-ink-button: #ffffff;
            --fb-blue: #1876f2;
            --success: #31a24c;
            --attention: #f2a918;
            --warning: #f7b928;
            --critical: #e41e3f;
            --critical-strong: #f0284a;
            --canvas: #ffffff;
            --surface-soft: #f1f4f7;
            --ink-deep: #0a1317;
            --ink: #1c1e21;
            --charcoal: #444950;
            --slate: #4b4c4f;
            --steel: #5d6c7b;
            --stone: #8595a4;
            --hairline: #ced0d4;
            --hairline-soft: #dee3e9;
            --disabled-text: #bcc0c4;
            
            /* Typography */
            --font-family: 'Montserrat', sans-serif;
        }

        body {
            font-family: var(--font-family);
            background-color: var(--surface-soft);
            color: var(--ink);
            font-size: 14px;
            font-weight: 400;
            line-height: 1.5;
            -webkit-font-smoothing: antialiased;
            letter-spacing: -0.14px;
        }

        h1, h2, h3, h4, h5, h6 {
            color: var(--ink-deep);
            font-weight: 500;
            letter-spacing: -0.2px;
        }

        /* Top Navigation */
        .ajo-navbar {
            background-color: var(--canvas);
            height: 64px;
            border-bottom: 1px solid var(--hairline-soft);
            padding: 0 24px;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .ajo-brand {
            font-size: 20px;
            font-weight: 700;
            color: var(--ink-deep) !important;
            letter-spacing: -0.5px;
            text-decoration: none !important;
        }

        .ajo-brand span {
            color: var(--primary);
        }

        /* Sidebar Navigation */
        .ajo-sidebar {
            position: fixed;
            top: 64px;
            bottom: 0;
            left: 0;
            width: 260px;
            background-color: var(--canvas);
            border-right: 1px solid var(--hairline-soft);
            padding: 24px 16px;
            z-index: 99;
            overflow-y: auto;
        }

        .nav-section-title {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            color: var(--steel);
            letter-spacing: 0.8px;
            margin-bottom: 12px;
            padding-left: 12px;
        }

        .ajo-nav-item {
            display: flex;
            align-items: center;
            padding: 12px 16px;
            color: var(--charcoal);
            font-weight: 500;
            border-radius: 100px; /* Pill style */
            margin-bottom: 4px;
            text-decoration: none !important;
            transition: all 0.2s ease-in-out;
        }

        .ajo-nav-item i {
            margin-right: 12px;
            font-size: 16px;
            width: 20px;
            text-align: center;
            color: var(--steel);
        }

        .ajo-nav-item:hover {
            background-color: var(--surface-soft);
            color: var(--ink-deep);
        }

        .ajo-nav-item.active {
            background-color: var(--primary-soft);
            color: var(--primary);
        }

        .ajo-nav-item.active i {
            color: var(--primary);
        }

        /* Main Content Layout */
        .ajo-main-container {
            margin-left: 260px;
            padding: 32px 40px;
            min-height: calc(100vh - 64px);
        }

        /* Cards styling */
        .ajo-card {
            background-color: var(--canvas);
            border: 1px solid var(--hairline-soft);
            border-radius: 16px; /* 16px rounded */
            padding: 24px;
            margin-bottom: 24px;
            transition: all 0.2s ease-in-out;
        }

        .ajo-card-lg {
            border-radius: 24px;
            padding: 32px;
        }

        .ajo-card-xl {
            border-radius: 32px;
            padding: 40px;
        }

        .ajo-card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--hairline-soft);
            padding-bottom: 16px;
            margin-bottom: 20px;
        }

        /* Pill Buttons styling */
        .btn-ajo-primary {
            background-color: var(--primary);
            color: var(--on-primary);
            font-weight: 700;
            border-radius: 100px;
            padding: 10px 24px;
            border: none;
            transition: all 0.2s ease-in-out;
        }

        .btn-ajo-primary:hover, .btn-ajo-primary:active, .btn-ajo-primary:focus {
            background-color: var(--primary-deep);
            color: var(--on-primary);
            box-shadow: none;
        }

        .btn-ajo-ink {
            background-color: var(--ink-button);
            color: var(--on-ink-button);
            font-weight: 700;
            border-radius: 100px;
            padding: 10px 24px;
            border: none;
            transition: all 0.2s ease-in-out;
        }

        .btn-ajo-ink:hover {
            background-color: var(--charcoal);
            color: var(--on-ink-button);
        }

        .btn-ajo-secondary {
            display: inline-block;
            background-color: transparent;
            color: var(--ink-deep);
            font-weight: 700;
            border: 2px solid var(--ink-deep);
            border-radius: 100px;
            padding: 8px 22px;
            transition: all 0.2s ease-in-out;
            cursor: pointer;
        }

        .btn-ajo-secondary:hover {
            background-color: var(--surface-soft);
            color: var(--ink-deep);
        }

        .btn-ajo-ghost {
            background-color: transparent;
            color: var(--ink-deep);
            font-weight: 700;
            border: 2px solid rgba(10, 19, 23, 0.12);
            border-radius: 100px;
            padding: 8px 22px;
            transition: all 0.2s ease-in-out;
        }

        /* Inputs */
        .ajo-input {
            border: 1px solid var(--hairline);
            border-radius: 8px;
            padding: 10px 16px;
            font-size: 14px;
            height: 44px;
            color: var(--ink);
            transition: all 0.2s ease-in-out;
        }

        .ajo-input:focus {
            border: 2px solid var(--fb-blue);
            box-shadow: none;
            outline: none;
        }

        /* Badges */
        .badge-ajo {
            font-weight: 700;
            font-size: 11px;
            border-radius: 100px;
            padding: 6px 14px;
            text-transform: uppercase;
            display: inline-block;
        }

        .badge-ajo-success {
            background-color: var(--success);
            color: #ffffff;
        }

        .badge-ajo-attention {
            background-color: var(--attention);
            color: #ffffff;
        }

        .badge-ajo-warning {
            background-color: var(--warning);
            color: var(--ink-deep);
        }

        .badge-ajo-critical {
            background-color: var(--critical);
            color: #ffffff;
        }

        /* Tables */
        .ajo-table {
            width: 100%;
            border-collapse: collapse;
        }

        .ajo-table th {
            font-weight: 700;
            color: var(--steel);
            text-transform: uppercase;
            font-size: 11px;
            letter-spacing: 0.5px;
            padding: 14px 16px;
            border-bottom: 1px solid var(--hairline-soft);
            text-align: left;
        }

        .ajo-table td {
            padding: 14px 16px;
            border-bottom: 1px solid var(--hairline-soft);
            color: var(--ink);
        }

        .ajo-table tr:last-child td {
            border-bottom: none;
        }

        /* Alerts */
        .ajo-alert {
            border-radius: 12px;
            padding: 16px;
            border: none;
            margin-bottom: 24px;
        }

        .ajo-alert-success {
            background-color: rgba(49, 162, 76, 0.1);
            color: var(--success);
        }

        .ajo-alert-danger {
            background-color: rgba(228, 30, 63, 0.1);
            color: var(--critical);
        }

        /* Custom scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }

        ::-webkit-scrollbar-track {
            background: var(--surface-soft);
        }

        ::-webkit-scrollbar-thumb {
            background: var(--hairline);
            border-radius: 100px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--stone);
        }

        /* Responsive Layout adjustments */
        @@media (max-width: 768px) {
            .ajo-sidebar {
                position: static;
                width: 100%;
                height: auto;
                border-right: none;
                border-bottom: 1px solid var(--hairline-soft);
                padding: 16px;
            }
            .ajo-main-container {
                margin-left: 0;
                padding: 20px;
            }
        }
    </style>
    @RenderSection("cssContent", required: false)
</head>
<body>
    @{
        var controllerName = ViewContext.RouteData.Values["controller"]?.ToString()?.ToLower() ?? "";
        var actionName = ViewContext.RouteData.Values["action"]?.ToString()?.ToLower() ?? "";
        var currentRole = Session["rules"] != null ? Session["rules"].ToString() : "Operator";
        var currentFullname = Session["name"] != null ? Session["name"].ToString() : "Operator";
    }

    <!-- Top Navigation -->
    <header class="ajo-navbar d-flex align-items-center justify-content-between">
        <a class="ajo-brand" href="@Url.Content("~/dashboard")">Ajo<span>Topup</span></a>
        
        <div class="d-flex align-items-center">
            <span class="mr-3 font-weight-500 text-secondary">
                <i class="far fa-user-circle mr-1"></i> Hi, <strong>@currentFullname</strong> (@currentRole)
            </span>
            <a href="@Url.Action("Logout", "Login")" class="btn-ajo-secondary text-decoration-none" style="padding: 6px 18px; font-size: 12px;">
                <i class="fas fa-sign-out-alt mr-1"></i> Sign Out
            </a>
        </div>
    </header>

    <!-- Sidebar Navigation -->
    <aside class="ajo-sidebar">
        <div class="nav-section-title">Menu Utama</div>
        
        <a href="@Url.Content("~/dashboard")" class="ajo-nav-item @(controllerName == "dashboard" ? "active" : "")">
            <i class="fas fa-chart-line"></i> Dashboard
        </a>
        
        <a href="@Url.Content("~/transaction")" class="ajo-nav-item @(controllerName == "transaction" && actionName == "index" ? "active" : "")">
            <i class="fas fa-mobile-alt"></i> Topup Pulsa
        </a>

        <a href="@Url.Content("~/transaction/history")" class="ajo-nav-item @(controllerName == "transaction" && actionName == "history" ? "active" : "")">
            <i class="fas fa-history"></i> Riwayat Transaksi
        </a>

        @if (currentRole == "sa")
        {
            <div class="nav-section-title mt-4">Administrasi</div>
            
            <a href="@Url.Content("~/product")" class="ajo-nav-item @(controllerName == "product" ? "active" : "")">
                <i class="fas fa-tags"></i> Master Produk
            </a>
            
            <a href="@Url.Content("~/admin")" class="ajo-nav-item @(controllerName == "admin" ? "active" : "")">
                <i class="fas fa-users-cog"></i> Kelola Pengguna
            </a>

            <a href="@Url.Content("~/admin/logs")" class="ajo-nav-item @(controllerName == "admin" && actionName == "logs" ? "active" : "")">
                <i class="fas fa-list-alt"></i> Log Request/Response
            </a>
        }
    </aside>

    <!-- Main Container -->
    <main class="ajo-main-container">
        @RenderBody()
    </main>

    <!-- Standard Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    @RenderSection("jsContent", required: false)
</body>
</html>
