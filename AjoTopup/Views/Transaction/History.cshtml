@{
    ViewBag.Title = "Riwayat Transaksi";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var products = ViewBag.ProductList as List<Dictionary<string, object>>;
}

<div class="row">
    <div class="col-12 mb-4">
        <h2 class="font-weight-700">Riwayat Transaksi</h2>
        <p class="text-secondary">Lihat, cari, dan filter data transaksi pengisian pulsa yang sudah dilakukan.</p>
    </div>
</div>

<!-- Filters Panel -->
<div class="ajo-card">
    <div class="ajo-card-header">
        <h5 class="font-weight-700 mb-0"><i class="fas fa-filter mr-2 text-primary"></i>Filter Transaksi</h5>
    </div>
    
    <div class="row">
        <!-- Date range -->
        <div class="col-md-3 mb-3">
            <label for="txtStartDate" class="font-weight-700 text-secondary" style="font-size: 11px;">TANGGAL MULAI</label>
            <input type="date" id="txtStartDate" class="form-control ajo-input" value="@DateTime.Now.AddDays(-7).ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-md-3 mb-3">
            <label for="txtEndDate" class="font-weight-700 text-secondary" style="font-size: 11px;">TANGGAL AKHIR</label>
            <input type="date" id="txtEndDate" class="form-control ajo-input" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
        </div>

        <!-- Status -->
        <div class="col-md-2 mb-3">
            <label for="ddlStatus" class="font-weight-700 text-secondary" style="font-size: 11px;">STATUS</label>
            <select id="ddlStatus" class="form-control ajo-input">
                <option value="">Semua Status</option>
                <option value="SUCCESS">SUCCESS</option>
                <option value="FAILED">FAILED</option>
                <option value="PENDING">PENDING</option>
            </select>
        </div>

        <!-- Product -->
        <div class="col-md-2 mb-3">
            <label for="ddlProductFilter" class="font-weight-700 text-secondary" style="font-size: 11px;">PRODUK</label>
            <select id="ddlProductFilter" class="form-control ajo-input">
                <option value="">Semua Produk</option>
                @if (products != null)
                {
                    foreach (var prod in products)
                    {
                        <option value="@prod["ProductCode"]">@prod["ProductName"]</option>
                    }
                }
            </select>
        </div>

        <!-- Search / Apply -->
        <div class="col-md-2 mb-3 d-flex align-items-end">
            <button type="button" id="btnApplyFilter" class="btn btn-ajo-primary btn-block">
                Cari <i class="fas fa-search ml-1"></i>
            </button>
        </div>
    </div>
</div>

<!-- Results Card -->
<div class="ajo-card">
    <div class="table-responsive">
        <table class="ajo-table" id="tblHistory">
            <thead>
                <tr>
                    <th>Trx ID</th>
                    <th>Tanggal</th>
                    <th>Produk</th>
                    <th>Nomor Tujuan</th>
                    <th>Nominal</th>
                    <th>Status</th>
                    <th>Pesan Provider</th>
                    <th>Aksi</th>
                </tr>
            </thead>
            <tbody id="historyBody">
                <tr>
                    <td colspan="8" class="text-center py-4 text-secondary">
                        <i class="fas fa-spinner fa-spin mr-2"></i> Mengambil data transaksi...
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="d-flex justify-content-between align-items-center mt-4">
        <div class="text-secondary" id="pageInfo">
            Menampilkan 0 dari 0 data
        </div>
        <div class="d-flex">
            <button type="button" id="btnPrev" class="btn btn-ajo-secondary mr-2" style="padding: 6px 16px; font-size: 12px;" disabled>
                <i class="fas fa-chevron-left mr-1"></i> Sebelumnya
            </button>
            <button type="button" id="btnNext" class="btn btn-ajo-secondary" style="padding: 6px 16px; font-size: 12px;" disabled>
                Selanjutnya <i class="fas fa-chevron-right ml-1"></i>
            </button>
        </div>
    </div>
</div>

@section jsContent {
    <script>
        $(document).ready(function () {
            var currentPage = 1;
            var pageSize = 10;
            var totalPages = 1;

            // Load data on start
            loadHistory();

            $('#btnApplyFilter').click(function () {
                currentPage = 1;
                loadHistory();
            });

            $('#btnPrev').click(function () {
                if (currentPage > 1) {
                    currentPage--;
                    loadHistory();
                }
            });

            $('#btnNext').click(function () {
                if (currentPage < totalPages) {
                    currentPage++;
                    loadHistory();
                }
            });

            function loadHistory() {
                var startDate = $('#txtStartDate').val();
                var endDate = $('#txtEndDate').val();
                var status = $('#ddlStatus').val();
                var productCode = $('#ddlProductFilter').val();

                $('#historyBody').html('<tr><td colspan="8" class="text-center py-4 text-secondary"><i class="fas fa-spinner fa-spin mr-2"></i> Mengambil data transaksi...</td></tr>');

                $.ajax({
                    url: '@Url.Content("~/api/transaction")',
                    type: 'GET',
                    data: {
                        startDate: startDate,
                        endDate: endDate,
                        status: status,
                        productCode: productCode,
                        pageNumber: currentPage,
                        pageSize: pageSize
                    },
                    success: function (res) {
                        if (res.statusCode === 200) {
                            var data = res.data;
                            var trxs = data.transactions;
                            totalPages = data.totalPages;

                            if (trxs.length === 0) {
                                $('#historyBody').html('<tr><td colspan="8" class="text-center py-4 text-secondary"><i class="fas fa-box-open mr-2"></i> Tidak ada data transaksi ditemukan.</td></tr>');
                                $('#pageInfo').text("Menampilkan 0 dari 0 data");
                                toggleNavButtons(false, false);
                                return;
                            }

                            var html = "";
                            for (var i = 0; i < trxs.length; i++) {
                                var t = trxs[i];
                                var badgeClass = "badge-ajo-attention";
                                if (t.status === "SUCCESS") badgeClass = "badge-ajo-success";
                                else if (t.status === "FAILED") badgeClass = "badge-ajo-critical";

                                // format date
                                var d = new Date(t.requestDate);
                                var formattedDate = d.toLocaleString('id-ID', { hour12: false });

                                html += "<tr>";
                                html += "<td class='font-weight-700'>" + t.trxId + "</td>";
                                html += "<td>" + formattedDate + "</td>";
                                html += "<td class='font-weight-500'>" + t.productName + "</td>";
                                html += "<td>" + t.destination + "</td>";
                                html += "<td>Rp " + parseFloat(t.amount).toLocaleString('id-ID') + "</td>";
                                html += "<td><span class='badge-ajo " + badgeClass + "'>" + t.status + "</span></td>";
                                html += "<td>" + (t.providerMessage || "-") + "</td>";
                                html += "<td><a href='@Url.Content("~/transaction/detail/")" + t.trxId + "' class='btn btn-ajo-primary btn-sm' style='padding: 4px 12px; font-size: 11px;'>Detail</a></td>";
                                html += "</tr>";
                            }

                            $('#historyBody').html(html);

                            // Update pagination UI
                            var startRecord = ((currentPage - 1) * pageSize) + 1;
                            var endRecord = startRecord + trxs.length - 1;
                            $('#pageInfo').text("Menampilkan " + startRecord + "-" + endRecord + " dari " + data.totalRecords + " data (Halaman " + currentPage + "/" + totalPages + ")");
                            
                            toggleNavButtons(currentPage > 1, currentPage < totalPages);
                        } else {
                            $('#historyBody').html('<tr><td colspan="8" class="text-center py-4 text-danger"><i class="fas fa-exclamation-triangle mr-2"></i> Gagal memuat data: ' + res.message + '</td></tr>');
                        }
                    },
                    error: function (xhr, status, err) {
                        $('#historyBody').html('<tr><td colspan="8" class="text-center py-4 text-danger"><i class="fas fa-exclamation-triangle mr-2"></i> Terjadi kesalahan koneksi sistem.</td></tr>');
                    }
                });
            }

            function toggleNavButtons(hasPrev, hasNext) {
                $('#btnPrev').prop('disabled', !hasPrev);
                $('#btnNext').prop('disabled', !hasNext);
            }
        });
    </script>
}

