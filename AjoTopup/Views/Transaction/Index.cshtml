@{
    ViewBag.Title = "Topup Pulsa";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var products = ViewBag.Products as List<Dictionary<string, object>>;
}

<div class="row justify-content-center">
    <div class="col-lg-8 col-md-10">
        <div class="mb-4">
            <h2 class="font-weight-700">Topup Pulsa Baru</h2>
            <p class="text-secondary">Pilih nominal produk dan masukkan nomor telepon tujuan transaksi.</p>
        </div>

        <div class="ajo-card ajo-card-lg">
            <div class="ajo-card-header">
                <h5 class="font-weight-700 mb-0"><i class="fas fa-paper-plane mr-2 text-primary"></i>Formulir Pengisian</h5>
            </div>

            <form id="frmTopup">
                <!-- Dropdown Product -->
                <div class="form-group mb-4">
                    <label for="ddlProduct">PILIH PRODUK PULSA</label>
                    <select id="ddlProduct" class="form-control ajo-input" required>
                        <option value="" disabled selected>-- Pilih Produk --</option>
                        @if (products != null)
                        {
                            foreach (var prod in products)
                            {
                                <option value="@prod["ProductCode"]" data-price="@prod["Price"]" data-provider="@prod["Provider"]" data-commission="@prod["Commission"]">
                                    @prod["ProductName"] - Rp @Convert.ToDecimal(prod["Price"]).ToString("N0") (@prod["Provider"])
                                </option>
                            }
                        }
                    </select>
                </div>

                <!-- Destination phone number -->
                <div class="form-group mb-4">
                    <label for="txtDestination">NOMOR TELEPON TUJUAN</label>
                    <input type="text" id="txtDestination" class="form-control ajo-input" placeholder="Contoh: 081234567890" maxlength="13" required />
                    <small class="form-text text-secondary mt-1">Harus diawali angka 0 dan panjang 8-12 digit angka.</small>
                </div>

                <!-- Product specs detail card (Meta prescription config summary style) -->
                <div id="productSummaryCard" class="p-3 mb-4" style="background-color: var(--surface-soft); border-radius: 12px; display: none;">
                    <h6 class="font-weight-700 mb-3 text-secondary" style="font-size: 11px; letter-spacing: 0.5px;">RINGKASAN PEMBELIAN</h6>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-secondary">Provider:</span>
                        <strong id="sumProvider" class="text-dark">-</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-secondary">Harga Produk:</span>
                        <strong id="sumPrice" class="text-dark">Rp 0</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-secondary">Komisi Agen:</span>
                        <strong id="sumCommission" class="text-success">Rp 0</strong>
                    </div>
                </div>

                <!-- Submit Button -->
                <button type="button" id="btnProcess" class="btn btn-ajo-primary btn-block py-2">
                    Proses Transaksi <i class="fas fa-chevron-right ml-1"></i>
                </button>
            </form>
        </div>
    </div>
</div>

<!-- Modal Dialog Result (Meta style alert banner / modal) -->
<div class="modal fade" id="resultModal" tabindex="-1" role="dialog" aria-hidden="true" data-backdrop="static">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content" style="border-radius: 24px; border: none; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
            <div id="resultHeader" class="p-4 text-center text-white" style="background-color: var(--success);">
                <i id="resultIcon" class="fas fa-check-circle mb-3" style="font-size: 56px;"></i>
                <h4 id="resultTitle" class="font-weight-700 mb-0">Transaksi Berhasil!</h4>
            </div>
            <div class="modal-body p-4">
                <div class="mb-3 d-flex justify-content-between border-bottom pb-2">
                    <span class="text-secondary">ID Transaksi:</span>
                    <strong id="resTrxId" class="text-dark">-</strong>
                </div>
                <div class="mb-3 d-flex justify-content-between border-bottom pb-2">
                    <span class="text-secondary">Nomor Tujuan:</span>
                    <strong id="resDestination" class="text-dark">-</strong>
                </div>
                <div class="mb-3 d-flex justify-content-between border-bottom pb-2">
                    <span class="text-secondary">Produk:</span>
                    <strong id="resProduct" class="text-dark">-</strong>
                </div>
                <div class="mb-3 d-flex justify-content-between border-bottom pb-2">
                    <span class="text-secondary">Serial Number (SN):</span>
                    <strong id="resSn" class="text-success">-</strong>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-secondary">Pesan Provider:</span>
                    <span id="resMessage" class="text-dark">-</span>
                </div>
            </div>
            <div class="modal-footer p-4 border-top-0 d-flex justify-content-between">
                <button type="button" id="btnGoToDetail" class="btn btn-ajo-secondary flex-fill mr-2" style="font-size: 13px;">
                    Lihat Detail
                </button>
                <button type="button" class="btn btn-ajo-primary flex-fill" data-dismiss="modal" style="font-size: 13px;">
                    Transaksi Baru
                </button>
            </div>
        </div>
    </div>
</div>

@section jsContent {
    <script>
        $(document).ready(function () {
            var selectedTrxId = "";

            // Dynamic summaries when selecting product
            $('#ddlProduct').change(function () {
                var selected = $(this).find('option:selected');
                if (selected.val() != "") {
                    var provider = selected.data('provider');
                    var price = parseFloat(selected.data('price'));
                    var commission = parseFloat(selected.data('commission'));

                    $('#sumProvider').text(provider);
                    $('#sumPrice').text('Rp ' + price.toLocaleString('id-ID'));
                    $('#sumCommission').text('Rp ' + commission.toLocaleString('id-ID'));
                    $('#productSummaryCard').slideDown();
                } else {
                    $('#productSummaryCard').slideUp();
                }
            });

            // Process button click
            $('#btnProcess').click(function () {
                var productCode = $('#ddlProduct').val();
                var destination = $('#txtDestination').val().trim();

                if (!productCode) {
                    alert("Silakan pilih produk terlebih dahulu.");
                    $('#ddlProduct').focus();
                    return;
                }

                if (!destination) {
                    alert("Silakan isi nomor tujuan.");
                    $('#txtDestination').focus();
                    return;
                }

                // regex check: 8-12 digits, starts with 0
                if (!/^0[0-9]{7,11}$/.test(destination)) {
                    alert("Nomor telepon tidak valid. Harus diawali angka 0 dan panjang 8-12 digit.");
                    $('#txtDestination').focus();
                    return;
                }

                // Loading state
                $('#btnProcess').prop('disabled', true).html('<i class="fas fa-spinner fa-spin mr-2"></i> Memproses Topup...');

                $.ajax({
                    url: '@Url.Action("Create", "Transaction")',
                    type: 'POST',
                    data: {
                        productCode: productCode,
                        destination: destination
                    },
                    success: function (res) {
                        $('#btnProcess').prop('disabled', false).html('Proses Transaksi <i class="fas fa-chevron-right ml-1"></i>');
                        
                        if (res.success) {
                            var data = res.data;
                            selectedTrxId = data.trxId;
                            
                            // Map modal values
                            $('#resTrxId').text(data.trxId);
                            $('#resDestination').text(data.destination);
                            $('#resProduct').text(data.productName);
                            
                            if (data.status === "SUCCESS") {
                                $('#resultHeader').css('background-color', 'var(--success)');
                                $('#resultIcon').attr('class', 'fas fa-check-circle mb-3');
                                $('#resultTitle').text("Transaksi Berhasil!");
                                $('#resSn').text(data.serialNumber || "-").removeClass('text-danger').addClass('text-success');
                                $('#resMessage').text(data.providerMessage || "-");
                            } else {
                                $('#resultHeader').css('background-color', 'var(--critical)');
                                $('#resultIcon').attr('class', 'fas fa-times-circle mb-3');
                                $('#resultTitle').text("Transaksi Gagal");
                                $('#resSn').text("TIDAK ADA").removeClass('text-success').addClass('text-danger');
                                $('#resMessage').text(data.providerMessage || "Ditolak oleh provider.");
                            }

                            $('#resultModal').modal('show');
                            
                            // Reset Form
                            $('#ddlProduct').val("");
                            $('#txtDestination').val("");
                            $('#productSummaryCard').hide();
                        } else {
                            alert("Transaksi Gagal: " + res.message);
                        }
                    },
                    error: function (xhr, err) {
                        $('#btnProcess').prop('disabled', false).html('Proses Transaksi <i class="fas fa-chevron-right ml-1"></i>');
                        alert("Terjadi kesalahan sistem: " + err);
                    }
                });
            });

            // Go to detail click inside modal
            $('#btnGoToDetail').click(function () {
                if (selectedTrxId) {
                    window.location = '@Url.Content("~/transaction/detail/")' + selectedTrxId;
                }
            });
        });
    </script>
}

